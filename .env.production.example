# Production environment template
# Fill values from your secret manager. Do not commit real secrets.

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
REDIS_URL=redis://<host>:6379
JWT_SECRET=<min-32-char-random-secret>
JWT_EXPIRES_IN=12h
API_PORT=3001
NEXT_PUBLIC_API_URL=https://<your-domain>
EXPO_PUBLIC_API_URL=https://<your-domain>
SEED_OWNER_EMAIL=<set-only-for-controlled-seeding>
SEED_OWNER_PASSWORD=<set-only-for-controlled-seeding>
